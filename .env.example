# ARG — example environment. Copy to `.env` and edit. `.env` is gitignored.
# All settings are local; no values point at remote services.

# --- Paths ---
ARG_DB_PATH=./arg_db
ARG_DOCS_PATH=./docs_corpus
ARG_CORPUS_NAME=default

# --- Ollama (local only) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.3:70b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Chunking ---
CHUNK_SIZE=1024
CHUNK_OVERLAP=128

# --- Retrieval ---
TOP_K_DENSE=10
TOP_K_BM25=10
TOP_K_FINAL=8
RRF_K=60
BM25_ENABLED=true

# --- DCI enrichment (Stage 0) ---
ENRICH_ENABLED=true
ENRICH_MIN_SCORE=0.5
ENRICH_TOP_DOCS=3
MIN_CLUSTER_DOCS=10

# --- Query processing ---
QUERY_REWRITE=true
QUERY_DECOMPOSE=true
HYDE_ENABLED=false

# --- Server ---
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=arg.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
DEBUG_TRACING=false

# --- LlamaIndex / telemetry hard-off ---
LLAMA_INDEX_TELEMETRY=False
ANONYMIZED_TELEMETRY=False
